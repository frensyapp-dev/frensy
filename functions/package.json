{
  "name": "functions",
  "scripts": {
    "lint": "node -e \"console.log('skip lint')\"",
    "build": "tsc",
    "build:watch": "tsc --watch",
    "serve": "npm run build && npx --yes firebase-tools emulators:start --only functions",
    "shell": "npm run build && npx --yes firebase-tools functions:shell",
    "start": "npm run shell",
    "deploy": "npx --yes firebase-tools deploy --only functions",
    "logs": "npx --yes firebase-tools functions:log"
  },
  "engines": {
    "node": "20"
  },
  "main": "lib/index.js",
  "dependencies": {
    "@google-cloud/vision": "^4.3.3",
    "firebase-admin": "^12.6.0",
    "firebase-functions": "^6.6.0"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^5.12.0",
    "@typescript-eslint/parser": "^5.12.0",
    "eslint": "^8.9.0",
    "eslint-config-google": "^0.14.0",
    "eslint-plugin-import": "^2.25.4",
    "firebase-functions-test": "^3.1.0",
    "typescript": "^5.7.3"
  },
  "private": true
}
